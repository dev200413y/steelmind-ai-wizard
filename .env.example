# OmniSense AI Wizard — Environment Variables
# Copy this file to .env and fill in your API keys

# Groq API (Free) — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
ORCHESTRATOR_MODEL=mixtral-8x7b-32768
DIAGNOSTIC_MODELS=mistral-small-3.1,mixtral-8x7b-32768,llama-3.3-70b-versatile,llama3-8b-8192
WHISPER_MODEL=base

# Google AI Studio (Free) — https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# Mistral API (Vision / Pixtral) — https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_VISION_MODEL=pixtral-12b-2409
